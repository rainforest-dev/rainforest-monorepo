---
import { useTranslation } from '@utils/i18n';

const lang = Astro.currentLocale === 'zh' ? 'zh' : 'en';
const { t } = await useTranslation(lang, 'common');
---

{/* Cycles system → light → dark. The click handler + scheme resolution live in
    the inline head script (layouts/head.astro), reached via the `data-theme-toggle`
    hook and event delegation — so this component is pure markup and survives
    view-transition swaps with no re-binding. The visible icon is driven by CSS
    from `html[data-theme-pref]`, which that script keeps in sync before paint. */}
<button
  type="button"
  data-theme-toggle
  aria-label={t('theme')}
  title={t('theme')}
  class="flex-center text-foreground/60 hover:text-foreground hover:bg-muted size-8 rounded-md transition-colors"
>
  <svg
    class="theme-ico theme-ico-system size-4.5"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect width="20" height="14" x="2" y="3" rx="2"></rect>
    <path d="M8 21h8M12 17v4"></path>
  </svg>
  <svg
    class="theme-ico theme-ico-light size-4.5"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
    ></path>
  </svg>
  <svg
    class="theme-ico theme-ico-dark size-4.5"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<style is:global>
  .theme-ico {
    display: none;
  }
  /* Default (attribute not yet set) shows the system icon. */
  :root:not([data-theme-pref]) .theme-ico-system,
  :root[data-theme-pref='system'] .theme-ico-system,
  :root[data-theme-pref='light'] .theme-ico-light,
  :root[data-theme-pref='dark'] .theme-ico-dark {
    display: block;
  }
</style>
