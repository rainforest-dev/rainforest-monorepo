---
import { hasCaseStudy } from '@rainforest-dev/portfolio/content';
import { type DataEntryMap, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';

type Props = DataEntryMap['projects'][string];

const { id, data } = Astro.props;
const { name } = data;

const lang = Astro.currentLocale ?? 'en';
const slug = id.split('/').pop()!;
const caseStudyHref = hasCaseStudy(slug)
  ? getRelativeLocaleUrl(lang, `/portfolio/${slug}`)
  : undefined;

const { Content } = await render(Astro.props);
---

<li
  class="**:[li]:list-disc **:[li]:list-inside **:[li]:text-xs sm:**:[li]:text-base"
>
  <h4 class="text-sm mb-0.5 mt-2 sm:text-lg sm:mb-1.5 sm:mt-3">
    {
      caseStudyHref ? (
        <a href={caseStudyHref} class="text-primary hover:underline">
          {name}
        </a>
      ) : (
        name
      )
    }
  </h4>
  <Content />
</li>
