---
import HomePage from '@components/pages/HomePage.astro';
import { fallbackLng, supportedLngs } from '@utils/i18n';

// Only non-default locales are prefixed under /[lang]; the default locale is at
// the root (see src/pages/index.astro), so it is excluded here.
export const prerender = true;
export function getStaticPaths() {
  return supportedLngs
    .filter((lng) => lng !== fallbackLng)
    .map((lang) => ({ params: { lang } }));
}
const lang = Astro.currentLocale === 'zh' ? 'zh' : 'en';
---

<HomePage lang={lang} />
