{
  "name": "@rainforest-monorepo/loop-observatory",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev --port 3003 --host 0.0.0.0",
    "build": "astro check && astro build",
    "preview": "astro preview --port 3003"
