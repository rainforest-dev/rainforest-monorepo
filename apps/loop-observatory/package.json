      "dev": { "dependsOn": ["^build"] },
      "build": { "dependsOn": ["^build"], "cache": true }
    }
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/vue": "7.0.1",
    "@lucide/vue": "^1.0.0",
    "@rainforest-dev/rainforest-ui": "workspace:*",
    "@tailwindcss/vite": "catalog:",
    "@vueuse/core": "^14.1.0",
    "astro": "7.1.3",
    "class-variance-authority": "catalog:",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  }
}
