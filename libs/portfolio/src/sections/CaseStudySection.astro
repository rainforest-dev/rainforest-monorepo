---
import type { InteractionKind, Section } from '../content/types';
import { AmmQuote } from '../islands/amm-quote';
import { EnvDeploy } from '../islands/env-deploy';
import { FetchThenStream } from '../islands/fetch-then-stream';
import { FuzzySearch } from '../islands/fuzzy-search';
import { I18nCard } from '../islands/i18n-card';
import { IdleLock } from '../islands/idle-lock';
import { LiveLedger } from '../islands/live-ledger';
import { OfferState } from '../islands/offer-state';
import { OrderBook } from '../islands/order-book';
import { PatchVsRefetch } from '../islands/patch-vs-refetch';
import { PhraseGrid } from '../islands/phrase-grid';
import { RelayGate } from '../islands/relay-gate';
import { VirtualizedSearch } from '../islands/virtualized-search';
import { WalletStateMachine } from '../islands/wallet-state-machine';
import { ZapLiquidity } from '../islands/zap-liquidity';
import { parseTech } from './parse-tech';

interface Props {
  section: Section;
}

const { section } = Astro.props;
const techSegments = parseTech(section.tech);

// Astro's `client:*` hydration directives require the tag to resolve to a component
// literally imported in this file (see the `NoMatchingImport` compiler error) — a
// runtime lookup (e.g. `islandFor(section.interaction)` returning a variable) isn't
// statically analyzable, so each known interaction kind gets its own branch here
// instead of a single dynamic `<Island />` tag. Unmapped kinds (the opencgt
// placeholders — see content/types.ts) render no island, same as before — tracked here
// so the wrapper `<div>` below is skipped entirely rather than left rendering empty.
const HYDRATED_KINDS: InteractionKind[] = [
  'phrase-grid',
  'fuzzy-search',
  'live-ledger',
  'idle-lock',
  'relay-gate',
  'virtualized-search',
  'order-book',
  'fetch-then-stream',
  'wallet-state-machine',
  'patch-vs-refetch',
  'amm-quote',
  'offer-state',
  'zap-liquidity',
  'env-deploy',
  'i18n-card',
];
const hasIsland = HYDRATED_KINDS.includes(section.interaction);
---

<section class="py-16" aria-labelledby={`sec-${section.id}`}>
  <p class="text-xs tracking-widest uppercase text-primary/70">{section.title}</p>
  <h3 id={`sec-${section.id}`} class="mt-2 text-2xl">{section.feature}</h3>
  <p class="mt-4 border-l-2 border-primary/50 pl-4 italic">{section.contribution}</p>
  <p class="mt-4 text-foreground/80">
    {
      techSegments.map((seg) =>
        seg.code ? (
          <code class="rounded bg-muted px-1 py-0.5 text-sm">{seg.text}</code>
        ) : (
          <span>{seg.text}</span>
        )
      )
    }
  </p>
  {
    hasIsland && (
      <div class="mt-8">
        {section.interaction === 'phrase-grid' && <PhraseGrid client:visible />}
        {section.interaction === 'fuzzy-search' && <FuzzySearch client:visible />}
        {section.interaction === 'live-ledger' && <LiveLedger client:visible />}
        {section.interaction === 'idle-lock' && <IdleLock client:visible />}
        {section.interaction === 'relay-gate' && <RelayGate client:visible />}
        {section.interaction === 'virtualized-search' && <VirtualizedSearch client:visible />}
        {section.interaction === 'order-book' && <OrderBook client:visible />}
        {section.interaction === 'fetch-then-stream' && <FetchThenStream client:visible />}
        {section.interaction === 'wallet-state-machine' && <WalletStateMachine client:visible />}
        {section.interaction === 'patch-vs-refetch' && <PatchVsRefetch client:visible />}
        {section.interaction === 'amm-quote' && <AmmQuote client:visible />}
        {section.interaction === 'offer-state' && <OfferState client:visible />}
        {section.interaction === 'zap-liquidity' && <ZapLiquidity client:visible />}
        {section.interaction === 'env-deploy' && <EnvDeploy client:visible />}
        {section.interaction === 'i18n-card' && <I18nCard client:visible />}
      </div>
    )
  }
  {section.sourceRef && <p class="mt-4 text-xs text-foreground/50">Mirrors {section.sourceRef}</p>}
</section>
